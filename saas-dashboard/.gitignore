# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key
*.p12

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets
.env
.env.*
!.env.example

# Firebase service account keys
*firebase-adminsdk*.json
serviceAccount*.json
firebase-service-account.json
service-account.json
credentials.json

# vercel
.vercel

# test artifacts
/test-results/
/playwright-report/
/coverage/

# typescript
*.tsbuildinfo
next-env.d.ts

# dependencies (if present locally)
/node_modules
